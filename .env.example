# Server Configuration
PORT=3000
NODE_ENV=development

# Trust Proxy - set to true when behind a reverse proxy (nginx, load balancer)
TRUST_PROXY=false

# Request Body Limit (in bytes) - default 1MB
REQUEST_BODY_LIMIT_BYTES=1048576

# Upstream Service URLs
AUTH_UPSTREAM_URL=http://localhost:4000
DIARY_UPSTREAM_URL=http://localhost:4100
TASKS_UPSTREAM_URL=http://localhost:4200
HEALTH_UPSTREAM_URL=http://localhost:4300

# Upstream Timeout (in milliseconds)
UPSTREAM_TIMEOUT_MS=30000

# Global Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECONDS=60

# Auth Endpoints Rate Limiting (stricter)
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=info
