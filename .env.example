# Server Configuration
PORT=3000
NODE_ENV=development

# Trust Proxy - set to true when behind a reverse proxy (nginx, load balancer)
TRUST_PROXY=false

# Request Body Limit (in bytes) - default 1MB
REQUEST_BODY_LIMIT_BYTES=1048576

# Upstream API service URLs
AUTH_UPSTREAM_URL=http://localhost:4001
DIARY_UPSTREAM_URL=http://localhost:4281

# Upstream frontend dev server URLs (Next.js apps)
# Both are served through the gateway at localhost:3000 to provide a single origin.
SHELL_UPSTREAM_URL=http://localhost:3001
DIARY_APP_UPSTREAM_URL=http://localhost:4280

# Upstream Timeout (in milliseconds)
UPSTREAM_TIMEOUT_MS=30000

# Global Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECONDS=60

# Auth Endpoints Rate Limiting (stricter)
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=info

# JWKS URL for verifying access tokens.
# auth-service exposes it at /v1/.well-known/jwks.json (versioned NestJS route).
# If unset, the gateway derives the URL from AUTH_UPSTREAM_URL (incorrect for NestJS versioned routes).
AUTH_JWKS_URL=http://localhost:4001/v1/.well-known/jwks.json

# ── Service-to-service trust ────────────────────────────────────────────────
# DIARY_SERVICE_TOKEN is a shared secret used to prove a request came from this
# gateway and not from a direct caller forging x-user-id headers.
#
# Requirements:
#   - Minimum 32 characters (enforced at startup)
#   - Must match GATEWAY_SERVICE_TOKEN in diary-api's environment
#   - Generate with: openssl rand -hex 32
#
# Example: DIARY_SERVICE_TOKEN=replace-with-a-32-char-random-secret-here
DIARY_SERVICE_TOKEN=
